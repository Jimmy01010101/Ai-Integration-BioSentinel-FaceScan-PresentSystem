generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
}

enum AttendanceStatus {
  HADIR
  ABSEN
  IZIN
  SAKIT
  CUTI
}

model SuperAdmin {
  id         Int      @id @default(autoincrement())
  username   String   @unique
  password   String
  fullName   String   @default("Super Admin") 
  isActive   Boolean  @default(true)

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Admin {
  id         Int      @id @default(autoincrement())
  username   String   @unique
  password   String
  fullName   String

  isActive   Boolean  @default(true)

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model User {
  id                Int      @id @default(autoincrement())

  fullName          String
  identityNumber    String   @unique
  division          String

  faceDescriptor    Json
  faceImage         String?

  isActive          Boolean  @default(true)

  attendances       Attendance[]

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model AttendanceSession {
  id           Int      @id @default(autoincrement())

  title        String

  startTime    DateTime
  endTime      DateTime

  isActive     Boolean  @default(true)

  attendances  Attendance[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Attendance {
  id                    Int      @id @default(autoincrement())

  userId                Int
  attendanceSessionId   Int

  confidenceScore       Float?

  smileVerified         Boolean  @default(false)
  blinkVerified         Boolean  @default(false)
  livenessVerified      Boolean  @default(false)

  spoofDetected         Boolean  @default(false)

  status                AttendanceStatus

  user                  User @relation(fields: [userId], references: [id])

  attendanceSession     AttendanceSession @relation(fields: [attendanceSessionId], references: [id])

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@unique([userId, attendanceSessionId])
} 

model SpoofLog {
  id           Int      @id @default(autoincrement())

  userId       Int?
  imagePath    String?

  reason       String

  createdAt    DateTime @default(now())
}

model SystemSetting {
  id            Int      @id @default(autoincrement())

  settingKey    String   @unique
  settingValue  String

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
} 